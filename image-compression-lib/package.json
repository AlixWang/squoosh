{
  "name": "@squoosh/image-compression-lib",
  "version": "1.0.0",
  "type": "module",
  "description": "A TypeScript library for image compression and format conversion based on Squoosh. Supports WebP, AVIF, JPEG XL, PNG, and MozJPEG formats with optimized performance for both Node.js and browser environments.",
  "homepage": "https://github.com/GoogleChromeLabs/squoosh/tree/dev/image-compression-lib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoogleChromeLabs/squoosh.git",
    "directory": "image-compression-lib"
  },
  "bugs": {
    "url": "https://github.com/GoogleChromeLabs/squoosh/issues"
  },
  "main": "dist/node/index.cjs",
  "browser": "dist/browser/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/esm/index.js",
        "require": "./dist/node/index.cjs",
        "types": "./dist/types/index.d.ts"
      },
      "browser": {
        "import": "./dist/browser/index.js",
        "script": "./dist/browser/index.umd.js",
        "types": "./dist/types/index.d.ts"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/node/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "script": "./dist/browser/index.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./node": {
      "import": "./dist/esm/index.js",
      "require": "./dist/node/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:rollup && npm run build:esm",
    "build:types": "tsc --project tsconfig.types.json",
    "build:rollup": "rollup -c rollup.config.js",
    "build:node": "rollup -c rollup.config.node.js",
    "build:browser": "rollup -c rollup.config.browser.js",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:webpack": "webpack --config webpack.config.js",
    "build:dev": "npm run clean && npm run build:types && npm run build:rollup -- --environment NODE_ENV:development",
    "build:prod": "npm run clean && npm run build:types && npm run build:rollup -- --environment NODE_ENV:production",
    "clean": "rimraf dist",
    "dev": "tsc --project tsconfig.node.json --watch",
    "dev:rollup": "rollup -c rollup.config.js --watch",
    "dev:webpack": "webpack --config webpack.config.js --watch",
    "analyze": "npm run build:browser && npx rollup-plugin-visualizer dist/browser/stats.html",
    "analyze:webpack": "npm run build:webpack -- --analyze",
    "size": "npm run build && node scripts/bundle-size.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "prepack": "npm run build",
    "postpack": "echo 'Package created successfully'",
    "version": "npm run build && git add -A dist",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "image",
    "compression",
    "webp",
    "avif",
    "jpeg-xl",
    "jxl",
    "png",
    "jpeg",
    "mozjpeg",
    "squoosh",
    "typescript",
    "browser",
    "nodejs",
    "wasm",
    "webassembly",
    "image-processing",
    "resize",
    "rotate",
    "quantize"
  ],
  "author": "Google Chrome Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.0.0",
    "gzip-size": "^7.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^23.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
